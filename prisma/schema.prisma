

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model User {
    id String @id @unique @default(uuid())
    userId  String @unique
    isVerified Boolean @default(false)
    email String @unique
    name String?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}